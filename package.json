{
  "name": "vscode-skobko-files",
  "displayName": "Skobko Files Support",
  "description": "Поддержка скобко-файлов",
  "version": "0.0.1",
  "license": "MPL-2.0",
  "author": "dmpas",
  "publisher": "dmpas",
  "repository": {
    "type": "git",
    "url": "https://github.com/dmpas/vscode-skobko-files"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "skobko",
        "aliases": [
          "Skobko File",
          "skobko"
        ],
        "extensions": [
          ".skb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skobko",
        "scopeName": "source.skobko",
        "path": "./syntaxes/skobko.tmLanguage.json"
      }
    ],
    "commands": []
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "echo \"no lint configured\"",
    "pretest": "npm run compile",
    "test": "mocha out/test/**/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "@types/mocha": "^10.0.6",
    "mocha": "^10.3.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  }
}
